# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
.Python
build/
dist/
*.egg-info/
*.egg
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
env/

# Testing / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.mypy_cache/
.ruff_cache/

# --- Local env & secrets ---
.env
.env.local

# --- IDE / editors ---
.vscode/
.idea/
*.swp
*.swo

# --- OS ---
.DS_Store
Thumbs.db

# --- Caddy runtime (if ever run from repo) ---
caddy_data/
caddy_config/

# --- Windows native deployment build outputs ---
# Binaries fetched or built locally (PyInstaller exe, caddy.exe, winsw.exe)
windows/dist/
# Transient PyInstaller venv used by build-relay.ps1
windows/.build-venv/
# Packaged release zips (final artifacts handed to ops)
windows/release/*.zip
# Re-include the Windows build scripts folder (the top-level `build/`
# rule above is meant for Python sdist/wheel outputs, not these sources).
!windows/build/
!windows/build/**
