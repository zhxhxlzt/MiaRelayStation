# -----------------------------------------------------------------------------
# Mia Cloud Relay · Windows deployment environment file (template)
#
# Copy this file to C:\ProgramData\Mia\config\.env on the target server and
# fill in real values. install.ps1 will do the copy for you if the target
# .env does not already exist.
#
# Format contract (enforced by the .cmd launcher in service/):
#   - One KEY=VALUE per line
#   - NO quotes around values  (KEY="foo" will include the quotes in $foo)
#   - NO trailing spaces on the value
#   - Lines starting with '#' are comments
#   - Blank lines are ignored
#
# Permissions: ACL on C:\ProgramData\Mia\config\ is tightened by install.ps1
# to SYSTEM + Administrators only.
# -----------------------------------------------------------------------------

# Comma-separated list of Bearer tokens accepted by the relay.
# Generate with (Windows PowerShell):
#   [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Max 256 } | ForEach-Object { [byte]$_ }))
# or on any box with openssl:
#   openssl rand -base64 32
MIA_AUTH_TOKENS=replace-me-with-a-strong-token,and-optionally-another

# Fully-qualified domain name Caddy will bind to and request a Let's Encrypt
# cert for. DNS A record MUST already point at this server's public IP before
# Caddy starts, otherwise ACME HTTP-01 challenge will fail.
MIA_DOMAIN=mia.example.com
